---
import { Image } from "astro:assets";
const { project, href } = Astro.props;

---

<a href={href} class="mb-4 max-w-1/1 rounded-xl shadow-xl ring-1 ring-white/10 hover:shadow-3xl sm:w-228 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cherry  "> 
    <div class="overflow-hidden rounded-xl bg-pink-wine">
	    <Image src={project.cover} alt={project.coverAlt} class="object-cover w-full h-48" /> 
    </div>
    <div class="m-4">
        <h4 class=" font-wix font-semibold tracking-tight text-onyx dark:text-pale-slate">{project.title}</h4>
        <p class="pb-1 text-sm font-noto line-clamp-3 text-onyx dark:text-pale-slate">{project.description}</p>
    </div>
</a>