---
//src/pages/projectPage.astro
import "../styles/global.css";
import ProjectPageLayout from "../layouts/ProjectPageLayout.astro";
---
<ProjectPageLayout>
    <h1 slot="title">Project Title</h1>
    <p slot="description">Detailed description of the project, your role, technologies used, and key achievements.</p>
    <div slot="content">
        <h2>Project Overview</h2>
        <p>Provide an overview of the project, its goals, and its impact.</p>
        <h2>Technologies Used</h2>
        <ul>
            <li>Technology 1</li>
            <li>Technology 2</li>
            <li>Technology 3</li>
        </ul>
        <h2>Key Contributions</h2>
        <p>Highlight your specific contributions to the project and any notable outcomes.</p>
    </div>
</ProjectPageLayout>